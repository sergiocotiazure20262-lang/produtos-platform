APP_ENV=testing # Define o ambiente de teste

DB_CONNECTION=mysql # Define o tipo de conexão com o banco de dados
DB_HOST=mysql # Define o host do banco de dados
DB_PORT=3306 # Define a porta do banco de dados
DB_DATABASE=produtos_test # Define o nome do banco de dados para testes
DB_USERNAME=root # Define o nome de usuário do banco de dados
DB_PASSWORD=root # Define a senha do banco de dados

# Configurações de cache para testes
CACHE_DRIVER=array # Não utiliza cache em ambiente de teste